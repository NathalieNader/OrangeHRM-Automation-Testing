<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke suite">
    <test name="Smoke test">
        <classes>
            <class name="LoginTest">
                <methods>
                    <include name="ValidLogIn"></include>
                    <include name="InvalidPassword"></include>
                    <include name="InvalidUsername"></include>
                    <include name="EmptyUsernameAndPassword"></include>
                    <include name="EmptyUsername"></include>
                    <include name="EmptyPassword"></include>
                </methods>
            </class>
            <class name="DashBoard">
                <methods>
                    <include name="PageLoadCorrect"/>
                    <include name="AdminUsernameDisplayed"/>
                    <include name="MenuItemsVisibleBeforeToggle"/>
                    <include name="MenuItemsVisibleAfterToggle"/>
                    <include name="QuickLaunchVisible"/>
                </methods>
            </class>
            <class name="PIM">
                <methods>
                    <include name="AddNewEmployee"/>
                    <include name="SearchEmployeeInList"/>
                    <include name="SearchEmployee"/>
                    <include name="EditEmployeeName"/>
                    <exclude name="SearchEmployeeAfterEdit"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>